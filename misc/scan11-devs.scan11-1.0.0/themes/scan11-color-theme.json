{
  "name": "SCAN-11 Nord",
  "type": "dark",
  "colors": {
    "editor.background": "#2E3440",
    "editor.foreground": "#D8DEE9",
    "editorCursor.foreground": "#D8DEE9",
    "editor.lineHighlightBackground": "#3B4252",
    "editorLineNumber.foreground": "#4C566A",
    "editorLineNumber.activeForeground": "#D8DEE9",
    "editorSelection.background": "#434C5E",
    "editorIndentGuide.background": "#3B4252",
    "editorIndentGuide.activeBackground": "#4C566A"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4C566A" }
    },
    {
      "name": "Strings and Characters",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#A3BE8C" }
    },
    {
      "name": "Escapes",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#EBCB8B" }
    },
    {
      "name": "Keywords and Operators",
      "scope": ["keyword", "keyword.control", "keyword.operator", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#81A1C1" }
    },
    {
      "name": "Numbers and Directives",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#B48EAD" }
    },
    {
      "name": "Literals (Booleans, Enums, Symbols)",
      "scope": ["constant.language", "constant.language.boolean", "constant.language.enum", "constant.other.symbol"],
      "settings": { "foreground": "#88C0D0" }
    },
    {
      "name": "Parentheses, Brackets, and Meta Punctuation",
      "scope": ["punctuation", "punctuation.definition", "punctuation.separator", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#E5E9F0" }
    },
    {
      "name": "Defined Functions/Types (Bold)",
      "scope": ["entity.name.function", "entity.name.type", "entity.name.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#D8DEE9", "fontStyle": "bold" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#D8DEE9" }
    }
  ]
}
